# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,amfitnaturalwellness.com,www.amfitnaturalwellness.com
CSRF_TRUSTED_ORIGINS=https://amfitnaturalwellness.com,https://www.amfitnaturalwellness.com

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=amfit_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://amfitnaturalwellness.com,https://www.amfitnaturalwellness.com

# Email Configuration (for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Flutterwave (Payment Integration - for future use)
FLUTTERWAVE_PUBLIC_KEY=your-public-key
FLUTTERWAVE_SECRET_KEY=your-secret-key

# Admin hardening
ADMIN_URL=admin/
ADMIN_LOGIN_EMAIL=admin@example.com
ADMIN_LOGIN_PASSWORD=change-this-password
ADMIN_LOGIN_USERNAME=admin

# Media uploads
MEDIA_URL=/media/
MEDIA_ROOT=media
